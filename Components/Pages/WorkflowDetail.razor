@page "/workflows/{WorkflowId}"
@page "/workflows/{WorkflowId}/runs/{RunId}"
@inject ITemporalOperationsService Temporal
@inject NavigationManager Nav

<PageTitle>@(IsRunDetail ? "Workflow Run Detail" : "Grouped Workflow Detail") - TemporalOps</PageTitle>

@if (_detail is null)
{
    <section class="empty-state">
        <p class="eyebrow">Workflow detail</p>
        <h1>Workflow not found</h1>
        <p>Check the Workflow ID and Run ID, then try again.</p>
        <button class="button" @onclick="BackToList">Back to list</button>
    </section>
}
else
{
    var workflow = _detail.Summary;
    <section class="detail-hero">
        <div>
            <p class="eyebrow">@(IsRunDetail ? "Workflow Run Detail" : "Grouped Workflow Detail")</p>
            <h1>@workflow.WorkflowId</h1>
            <div class="detail-tags">
                <StatusBadge Value="@workflow.Status" />
                <StatusBadge Value="@workflow.Risk" />
                <code>@workflow.TaskQueue</code>
                <span>@workflow.WorkflowType</span>
                @if (IsRunDetail)
                {
                    <span>run <code>@ShortRunId(workflow.RunId)</code></span>
                }
                else if (workflow.HasContinuationChain)
                {
                    <span>@workflow.ContinuationRunCount grouped runs</span>
                }
            </div>
        </div>
        <div class="detail-actions">
            <button class="button button-ghost" @onclick="BackToList">Back to workflows</button>
            @if (IsRunDetail)
            {
                <button class="button button-ghost" @onclick="OpenGroupedDetail">Grouped details</button>
            }
            else if (!string.IsNullOrWhiteSpace(workflow.RunId))
            {
                <button class="button button-ghost" @onclick="() => OpenRunDetail(workflow.WorkflowId, workflow.RunId)">Current run details</button>
            }
            <button class="button" @onclick="() => _selectedWorkflow = workflow">Operator action</button>
        </div>
    </section>

    @if (IsRunDetail)
    {
        <section class="panel detail-focus-panel">
            <div>
                <p class="eyebrow">Execution focus</p>
                <h2>Single-run motion</h2>
                <p class="muted-text">Focused view for one Workflow ID / Run ID. Use grouped details when you need the full Continue-As-New chain context.</p>
            </div>
            <div class="detail-focus-grid">
                <div><span>Run ID</span><strong><code>@ShortRunId(workflow.RunId)</code></strong></div>
                <div><span>Status</span><StatusBadge Value="@workflow.Status" /></div>
                <div><span>Started</span><strong>@FormatDateTime(workflow.StartedAt)</strong></div>
                <div><span>Closed</span><strong>@(workflow.ClosedAt?.ToLocalTime().ToString("yyyy/MM/dd HH:mm:ss") ?? "running")</strong></div>
            </div>
        </section>

        <WorkflowMotionView Motion="@_detail.Motion" />
    }
    else
    {
        <section class="panel grouped-detail-overview">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">Grouped workflow overview</p>
                    <h2>Operational summary</h2>
                </div>
                <span class="chain-badge">@workflow.ContinuationRunCount run(s)</span>
            </div>
            <div class="detail-focus-grid grouped-overview-grid">
                <div><span>Current run</span><strong><code>@ShortRunId(workflow.RunId)</code></strong></div>
                <div><span>Status</span><StatusBadge Value="@workflow.Status" /></div>
                <div><span>Business window</span><strong>@FormatDateTime(workflow.StartedAt)</strong></div>
                <div><span>Latency</span><strong>@workflow.LatencySeconds.ToString("N1")s</strong></div>
                <div><span>History</span><strong>@workflow.HistoryLength</strong></div>
                <div><span>Pending</span><strong>@workflow.PendingActivities</strong></div>
            </div>
            <p class="muted-text">Grouped details stay compact for operational review. Open a run detail below when you need the motion view for one execution.</p>
        </section>

        @if (_detail.ContinuationRuns.Count > 0)
        {
            <section class="panel panel-wide">
                <div class="panel-header">
                    <div>
                        <p class="eyebrow">Continue-As-New context</p>
                        <h2>Run chain</h2>
                    </div>
                    <span class="chain-badge">@_detail.ContinuationRuns.Count runs</span>
                </div>
                <div class="detail-run-chain">
                    @foreach (var run in _detail.ContinuationRuns.OrderBy(r => r.StartedAt))
                    {
                        <div class="@DetailRunClass(run)">
                            <div class="detail-run-grid detail-run-grid-with-action">
                                <div class="chain-run-field chain-run-id-field">
                                    <span class="chain-field-label">Run ID</span>
                                    <div class="chain-run-idline">
                                        <strong>@ShortRunId(run.RunId)</strong>
                                        @if (run.IsCurrent)
                                        {
                                            <span class="current-chip">current</span>
                                        }
                                    </div>
                                </div>
                                <div class="chain-run-field">
                                    <span class="chain-field-label">Status</span>
                                    <StatusBadge Value="@run.Status" />
                                </div>
                                <div class="chain-run-field">
                                    <span class="chain-field-label">Start Time</span>
                                    <strong>@FormatDateTime(run.StartedAt)</strong>
                                </div>
                                <div class="chain-run-field">
                                    <span class="chain-field-label">Close Time</span>
                                    <strong>@FormatCloseTime(run)</strong>
                                </div>
                                <div class="chain-run-field compact-field">
                                    <span class="chain-field-label">History</span>
                                    <strong>@run.HistoryLength</strong>
                                </div>
                                <div class="chain-run-field compact-field">
                                    <span class="chain-field-label">Latency</span>
                                    <strong>@run.LatencySeconds.ToString("N1")s</strong>
                                </div>
                                <div class="chain-run-field compact-field chain-run-action-field">
                                    <span class="chain-field-label">Detail</span>
                                    <button class="button button-ghost button-compact" title="Open run detail and motion" @onclick="() => OpenRunDetail(run.WorkflowId, run.RunId)">Run details</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }
    }

    <section class="detail-grid">
        <article class="panel">
            <div class="panel-header"><h2>Execution metadata</h2></div>
            <dl class="meta-grid">
                <dt>Workflow ID</dt><dd><code>@workflow.WorkflowId</code></dd>
                <dt>Run ID</dt><dd><code>@workflow.RunId</code></dd>
                <dt>Started</dt><dd>@workflow.StartedAt.ToLocalTime().ToString("yyyy/MM/dd HH:mm:ss")</dd>
                <dt>Closed</dt><dd>@(workflow.ClosedAt?.ToLocalTime().ToString("yyyy/MM/dd HH:mm:ss") ?? "-")</dd>
                <dt>Attempt</dt><dd>@workflow.Attempt</dd>
                <dt>Pending Activities</dt><dd>@workflow.PendingActivities</dd>
                <dt>History Length</dt><dd>@workflow.HistoryLength</dd>
                <dt>Search Attrs</dt><dd>@workflow.SearchAttributes</dd>
            </dl>
        </article>

        <article class="panel">
            <div class="panel-header"><h2>Open Signals</h2></div>
            <div class="signal-list">
                @foreach (var signal in _detail.OpenSignals)
                {
                    <button class="pill" @onclick="() => StartSignal(signal)">@signal</button>
                }
            </div>
            <p class="muted-text">Common signals can be prefilled in Operator Action.</p>
        </article>

        <article class="panel panel-wide">
            <div class="panel-header">
                <div>
                    <p class="eyebrow">History</p>
                    <h2>@(IsRunDetail ? "Run event timeline" : "Grouped current-run timeline")</h2>
                </div>
            </div>
            <div class="timeline">
                @foreach (var history in _detail.History)
                {
                    <div class="timeline-item @(history.IsProblem ? "is-problem" : null)">
                        <span>@history.EventId</span>
                        <div>
                            <strong>@history.EventType</strong>
                            <p>@history.Details</p>
                            <small>@history.Timestamp.ToLocalTime().ToString("HH:mm:ss")</small>
                        </div>
                    </div>
                }
            </div>
        </article>

        <article class="panel">
            <div class="panel-header"><h2>Input</h2></div>
            <pre class="json-box">@_detail.InputJson</pre>
        </article>

        <article class="panel">
            <div class="panel-header"><h2>Memo / Runbook</h2></div>
            <pre class="json-box">@_detail.MemoJson</pre>
        </article>
    </section>

    <ActionDrawer Workflow="@_selectedWorkflow" Service="@Temporal" OnClose="CloseActionDrawer" OnChanged="ReloadAsync" />
}

@code {
    [Parameter] public string? WorkflowId { get; set; }
    [Parameter] public string? RunId { get; set; }

    private TemporalOpsBlazor.Models.WorkflowDetail? _detail;
    private WorkflowExecutionSummary? _selectedWorkflow;

    private bool IsRunDetail => !string.IsNullOrWhiteSpace(RunId);

    protected override Task OnParametersSetAsync() => ReloadAsync();

    private async Task ReloadAsync()
    {
        if (!string.IsNullOrWhiteSpace(WorkflowId))
        {
            _detail = await Temporal.GetWorkflowAsync(WorkflowId, RunId);
        }
    }

    private void CloseActionDrawer() => _selectedWorkflow = null;

    private void BackToList() => Nav.NavigateTo("/workflows");

    private void OpenGroupedDetail()
    {
        if (!string.IsNullOrWhiteSpace(WorkflowId))
        {
            Nav.NavigateTo($"/workflows/{Uri.EscapeDataString(WorkflowId)}");
        }
    }

    private void OpenRunDetail(string workflowId, string runId)
    {
        if (!string.IsNullOrWhiteSpace(workflowId) && !string.IsNullOrWhiteSpace(runId))
        {
            Nav.NavigateTo($"/workflows/{Uri.EscapeDataString(workflowId)}/runs/{Uri.EscapeDataString(runId)}");
        }
    }

    private void StartSignal(string signalName)
    {
        _selectedWorkflow = _detail?.Summary;
    }

    private bool IsRunDetailFor(WorkflowRunSummary run) =>
        !string.IsNullOrWhiteSpace(RunId) &&
        string.Equals(run.RunId, RunId, StringComparison.OrdinalIgnoreCase);

    private static string DetailRunClass(WorkflowRunSummary run) =>
        run.IsCurrent ? "detail-run-node is-current" : "detail-run-node";

    private static string FormatDateTime(DateTimeOffset value) =>
        value.ToLocalTime().ToString("yyyy/MM/dd HH:mm:ss");

    private static string FormatCloseTime(WorkflowRunSummary run) =>
        run.ClosedAt?.ToLocalTime().ToString("yyyy/MM/dd HH:mm:ss") ?? "running";

    private static string ShortRunId(string? runId)
    {
        if (string.IsNullOrWhiteSpace(runId))
        {
            return "-";
        }

        return runId.Length <= 8 ? runId : runId[..8];
    }
}
