@inject NavigationManager Nav

<div class="table-shell">
    <table class="data-table workflow-group-table">
        <thead>
            <tr>
                <th>Workflow</th>
                <th>Status</th>
                <th>Risk</th>
                <th>Runs</th>
                <th>Task Queue</th>
                <th>Pending</th>
                <th>Latency</th>
                <th>Owner</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var workflow in Items)
        {
            var isExpanded = IsExpanded(workflow);
            <tr class="@RowClass(workflow, isExpanded)">
                <td>
                    <div class="workflow-cell workflow-cell-with-toggle">
                        @if (workflow.HasContinuationChain)
                        {
                            <button class="chain-toggle" title="@ToggleTitle(isExpanded)" aria-label="@ToggleTitle(isExpanded)" @onclick="() => Toggle(workflow)">
                                <span class="@ToggleIconClass(isExpanded)">▾</span>
                            </button>
                        }
                        <div class="workflow-cell-main">
                            <strong>@workflow.WorkflowId</strong>
                            <span>@workflow.WorkflowType</span>
                            @if (workflow.HasContinuationChain)
                            {
                                <small class="chain-note">current run: <code>@ShortRunId(workflow.RunId)</code></small>
                            }
                            else
                            {
                                <small class="chain-note">run: <code>@ShortRunId(workflow.RunId)</code></small>
                            }
                        </div>
                    </div>
                </td>
                <td><StatusBadge Value="@workflow.Status" /></td>
                <td><StatusBadge Value="@workflow.Risk" /></td>
                <td>
                    @if (workflow.HasContinuationChain)
                    {
                        <button class="chain-badge" title="@ToggleTitle(isExpanded)" @onclick="() => Toggle(workflow)">
                            Continue-As-New × @workflow.ContinuationRunCount
                        </button>
                    }
                    else
                    {
                        <span class="muted-text">1</span>
                    }
                </td>
                <td><code>@workflow.TaskQueue</code></td>
                <td>@workflow.PendingActivities</td>
                <td>@workflow.LatencySeconds.ToString("N1")s</td>
                <td>@workflow.Owner</td>
                <td class="row-actions">
                    <button class="button button-ghost" title="Open grouped workflow detail" @onclick="() => OpenGroupedDetail(workflow)">Grouped details</button>
                    <button class="button button-compact" title="Open guarded operator actions" @onclick="() => OnAction.InvokeAsync(workflow)">Action</button>
                </td>
            </tr>
            @if (workflow.HasContinuationChain && isExpanded)
            {
                <tr class="chain-detail-row">
                    <td colspan="9">
                        <div class="chain-detail">
                            <div class="chain-detail-header">
                                <strong>Continue-As-New run chain</strong>
                                <span>Current run first, then newest to oldest. Opened chains stay open after refresh.</span>
                            </div>
                            <div class="chain-timeline">
                                @foreach (var run in OrderedRuns(workflow))
                                {
                                    <div class="@ChainRunClass(run)">
                                        <div class="chain-dot"></div>
                                        <div class="chain-run-body">
                                            <div class="chain-run-grid detail-run-grid-with-action">
                                                <div class="chain-run-field chain-run-id-field">
                                                    <span class="chain-field-label">Run ID</span>
                                                    <div class="chain-run-idline">
                                                        <code>@ShortRunId(run.RunId)</code>
                                                        @if (run.IsCurrent)
                                                        {
                                                            <span class="current-chip">current</span>
                                                        }
                                                    </div>
                                                </div>
                                                <div class="chain-run-field">
                                                    <span class="chain-field-label">Status</span>
                                                    <StatusBadge Value="@run.Status" />
                                                </div>
                                                <div class="chain-run-field">
                                                    <span class="chain-field-label">Start Time</span>
                                                    <strong>@FormatDateTime(run.StartedAt)</strong>
                                                </div>
                                                <div class="chain-run-field">
                                                    <span class="chain-field-label">Close Time</span>
                                                    <strong>@FormatCloseTime(run)</strong>
                                                </div>
                                                <div class="chain-run-field compact-field">
                                                    <span class="chain-field-label">History</span>
                                                    <strong>@run.HistoryLength</strong>
                                                </div>
                                                <div class="chain-run-field compact-field">
                                                    <span class="chain-field-label">Latency</span>
                                                    <strong>@run.LatencySeconds.ToString("N1")s</strong>
                                                </div>
                                                <div class="chain-run-field compact-field chain-run-action-field">
                                                    <span class="chain-field-label">Detail</span>
                                                    <button class="button button-ghost button-compact" title="Open run detail and motion" @onclick="() => OpenRunDetail(run.WorkflowId, run.RunId)">Run details</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<WorkflowExecutionSummary> Items { get; set; } = [];
    [Parameter] public EventCallback<WorkflowExecutionSummary> OnAction { get; set; }
    private readonly HashSet<string> _expandedWorkflowIds = new(StringComparer.OrdinalIgnoreCase);

    private void OpenGroupedDetail(WorkflowExecutionSummary workflow) =>
        Nav.NavigateTo($"/workflows/{Uri.EscapeDataString(workflow.WorkflowId)}");

    private void OpenRunDetail(string workflowId, string runId)
    {
        if (!string.IsNullOrWhiteSpace(workflowId) && !string.IsNullOrWhiteSpace(runId))
        {
            Nav.NavigateTo($"/workflows/{Uri.EscapeDataString(workflowId)}/runs/{Uri.EscapeDataString(runId)}");
        }
    }

    private bool IsExpanded(WorkflowExecutionSummary workflow) =>
        workflow.HasContinuationChain && _expandedWorkflowIds.Contains(workflow.WorkflowId);

    private void Toggle(WorkflowExecutionSummary workflow)
    {
        if (!_expandedWorkflowIds.Add(workflow.WorkflowId))
        {
            _expandedWorkflowIds.Remove(workflow.WorkflowId);
        }
    }

    private static IEnumerable<WorkflowRunSummary> OrderedRuns(WorkflowExecutionSummary workflow) =>
        workflow.ContinuationRuns
            .OrderByDescending(r => r.IsCurrent)
            .ThenByDescending(r => r.StartedAt);

    private static string ToggleTitle(bool isExpanded) =>
        isExpanded ? "Collapse run chain" : "Show run chain";

    private static string RowClass(WorkflowExecutionSummary workflow, bool isExpanded)
    {
        var classes = new List<string>();
        if (workflow.HasContinuationChain) classes.Add("has-chain");
        if (isExpanded) classes.Add("is-expanded");
        return string.Join(" ", classes);
    }

    private static string ToggleIconClass(bool isExpanded) =>
        isExpanded ? "is-open" : string.Empty;

    private static string ChainRunClass(WorkflowRunSummary run) =>
        run.IsCurrent ? "chain-run is-current" : "chain-run";

    private static string FormatDateTime(DateTimeOffset value) =>
        value.ToLocalTime().ToString("yyyy/MM/dd HH:mm:ss");

    private static string FormatCloseTime(WorkflowRunSummary run) =>
        run.ClosedAt?.ToLocalTime().ToString("yyyy/MM/dd HH:mm:ss") ?? "running";

    private static string ShortRunId(string? runId)
    {
        if (string.IsNullOrWhiteSpace(runId))
        {
            return "-";
        }

        return runId.Length <= 8 ? runId : runId[..8];
    }
}
