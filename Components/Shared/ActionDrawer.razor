@if (Workflow is not null)
{
    <div class="drawer-backdrop" @onclick="Close"></div>
    <aside class="action-drawer">
        <div class="drawer-header">
            <div>
                <p class="eyebrow">Operator action</p>
                <h2>@Workflow.WorkflowId</h2>
                <span>@Workflow.WorkflowType / <code>@Workflow.RunId</code></span>
            </div>
            <button class="icon-button" @onclick="Close" aria-label="Close">×</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="toast @(Succeeded ? "toast-success" : "toast-error")">@Message</div>
        }

        <div class="danger-panel">
            <strong>Safety guard</strong>
            <p>Cancel allows workflow cleanup. Terminate and Reset are high-impact actions, so they require a reason and two-step confirmation.</p>
        </div>

        <EditForm Model="@this" OnValidSubmit="RunActionAsync">
            <div class="form-stack">
                <label>
                    Action
                    <select @bind="SelectedAction">
                        <option value="signal">Send Signal</option>
                        <option value="cancel">Request Cancel</option>
                        <option value="reset">Reset from event</option>
                        <option value="terminate">Terminate</option>
                    </select>
                </label>

                @if (SelectedAction == "signal")
                {
                    <label>
                        Signal name
                        <input @bind="SignalName" placeholder="refreshInventory" />
                    </label>
                    <label>
                        Payload JSON
                        <textarea @bind="PayloadJson" rows="5"></textarea>
                    </label>
                }

                @if (SelectedAction == "reset")
                {
                    <label>
                        Reset Event ID
                        <input type="number" @bind="ResetEventId" />
                    </label>
                }

                <label>
                    Reason <span class="required">required</span>
                    <textarea @bind="Reason" rows="4" placeholder="Record the incident ticket, decision rationale, and expected outcome."></textarea>
                </label>

                @if (SelectedAction is "terminate" or "reset")
                {
                    <label>
                        Confirmation
                        <input @bind="Confirmation" placeholder="@($"Type {Workflow.WorkflowId} to confirm")" />
                    </label>
                }

                <button class="button button-danger" disabled="@IsBusy">@ButtonText</button>
            </div>
        </EditForm>
    </aside>
}

@code {
    [Parameter] public WorkflowExecutionSummary? Workflow { get; set; }
    [Parameter, EditorRequired] public ITemporalOperationsService Service { get; set; } = default!;
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private string SelectedAction { get; set; } = "signal";
    private string SignalName { get; set; } = "operatorOverride";
    private string PayloadJson { get; set; } = "{\n  \"priority\": \"high\",\n  \"note\": \"checked by operator\"\n}";
    private string Reason { get; set; } = string.Empty;
    private string Confirmation { get; set; } = string.Empty;
    private long ResetEventId { get; set; } = 43;
    private bool IsBusy { get; set; }
    private string? Message { get; set; }
    private bool Succeeded { get; set; }

    private string ButtonText => SelectedAction switch
    {
        "signal" => "Send Signal",
        "cancel" => "Request Cancel",
        "reset" => "Run Reset",
        "terminate" => "Run Terminate",
        _ => "Run"
    };

    private async Task RunActionAsync()
    {
        if (Workflow is null) return;
        Message = null;

        if (string.IsNullOrWhiteSpace(Reason))
        {
            Succeeded = false;
            Message = "Enter an action reason.";
            return;
        }

        if (SelectedAction is "terminate" or "reset" && Confirmation != Workflow.WorkflowId)
        {
            Succeeded = false;
            Message = "Confirmation does not match the Workflow ID.";
            return;
        }

        IsBusy = true;
        OperationResult result;
        try
        {
            result = SelectedAction switch
            {
                "signal" => await Service.SendSignalAsync(Workflow.WorkflowId, Workflow.RunId, SignalName, PayloadJson, Reason),
                "cancel" => await Service.RequestCancellationAsync(Workflow.WorkflowId, Workflow.RunId, Reason),
                "reset" => await Service.ResetAsync(Workflow.WorkflowId, Workflow.RunId, ResetEventId, Reason),
                "terminate" => await Service.TerminateAsync(Workflow.WorkflowId, Workflow.RunId, Reason),
                _ => OperationResult.Fail("Unsupported action.")
            };
        }
        finally
        {
            IsBusy = false;
        }

        Succeeded = result.Succeeded;
        Message = result.Message;
        if (result.Succeeded)
        {
            Reason = string.Empty;
            Confirmation = string.Empty;
            await OnChanged.InvokeAsync();
        }
    }

    private Task Close() => OnClose.InvokeAsync();
}
